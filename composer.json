{
  "name": "nexphant/nexphant",
  "description": "The Nexphant application skeleton.",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "nexphant/framework": "^0.0",
    "nexphant/dev": "^0.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "post-create-project-cmd": [
      "@php setup.php"
    ],
    "setup": "php setup.php",
    "dev": "php nexphant.dev.php",
    "serve": "php app.php",
    "dump": "composer dump-autoload -o"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}